<Window x:Class="TestTask.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Сотрудники">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Staffers}" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectedItem="{Binding SelectedStaffer}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*" />
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="120" />
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding Birth, StringFormat={}{0:dd.MM.yyyy}}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Добавить" Command="{Binding AddStafferCommand}" Padding="10,5" Margin="0,0,5,0" />
                        <Button Content="Редактировать" Command="{Binding EditStafferCommand}" Padding="10,5" Margin="0,0,5,0" />
                        <Button Content="Удалить" Command="{Binding DeleteStafferCommand}" Padding="10,5" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Контрагенты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding CounterAgents}" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectedItem="{Binding SelectedCounterAgent}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="150" />
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding StafferFullName}" Width="200" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Добавить" Command="{Binding AddCounterAgentCommand}" Padding="10,5" Margin="0,0,5,0" />
                        <Button Content="Редактировать" Command="{Binding EditCounterAgentCommand}" Padding="10,5" Margin="0,0,5,0" />
                        <Button Content="Удалить" Command="{Binding DeleteCounterAgentCommand}" Padding="10,5" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectedItem="{Binding SelectedOrder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Sum}" Width="100" />
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" Width="120" />
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding StafferFullName}" Width="*" />
                            <DataGridTextColumn Header="Контрагент" Binding="{Binding CounterAgentName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Добавить" Command="{Binding AddOrderCommand}" Padding="10,5" Margin="0,0,5,0" />
                        <Button Content="Редактировать" Command="{Binding EditOrderCommand}" Padding="10,5" Margin="0,0,5,0" />
                        <Button Content="Удалить" Command="{Binding DeleteOrderCommand}" Padding="10,5" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
